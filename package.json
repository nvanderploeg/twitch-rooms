{
  "name": "twitch-room",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Twitch Room — a shared, configurable virtual room where a Streamer's Viewers gather.",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^4.3.2",
    "jsdom": "^29.1.1",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "vitest": "^3.2.6"
  }
}
